<!-- index.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
     <link rel="stylesheet" href="/styles.css">
    <title><%= title %></title>
</head>
<body>
    <%- include("navbar", { links: links }) %>
    <h1><%= title %></h1>
    <p><%= message %></p>
    <ul>
        <% users.forEach(user => { %>
           <%- include("users/user", { user: user }) %>
        <% }) %>
        <%- include("footer") %>
    </ul>
</body>
</html>